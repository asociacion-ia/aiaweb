---

---

<section id="ubicacion" class="py-20 bg-[#F4F5F0]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
            <h2
                class="text-3xl md:text-4xl font-bold text-[#4D40AC] mb-4"
                data-i18n="location.title"
            >
                Sede del Evento
            </h2>
            <div class="h-1 w-20 bg-[#221965] mx-auto rounded-full mb-6"></div>

            <p
                class="text-lg text-gray-700 max-w-2xl mx-auto leading-relaxed"
                data-i18n="location.desc"
            >
                Te esperamos en el Campus de Móstoles de la URJC, un espacio
                diseñado para la innovación y el desarrollo tecnológico.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
            <!-- Information Card -->
            <div
                class="bg-white rounded-xl p-8 shadow-sm border border-gray-100 flex flex-col justify-center"
                data-aos="fade-right"
            >
                <div
                    class="text-[#4D40AC] mb-6 p-3 bg-indigo-50 rounded-full w-12 h-12 flex items-center justify-center"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                        ></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                </div>

                <h3
                    class="text-xl font-bold text-[#221965] mb-4"
                    data-i18n="location.lab"
                >
                    Laboratorios de Informática
                </h3>

                <div class="space-y-4 mb-8">
                    <p class="text-gray-600 leading-relaxed font-medium">
                        Calle Tulipán, s/n, 28933 Móstoles. <br />
                        <span class="text-gray-500 font-normal"
                            >Edificio Departamental (Laboratorios de IA).</span
                        >
                    </p>

                    <p
                        class="text-gray-500 leading-relaxed text-sm"
                        data-i18n="location.facilities"
                    >
                        Contamos con instalaciones de última generación y un
                        ambiente perfecto para trabajar en equipo durante las 48
                        horas del hackathon.
                    </p>
                </div>

                <div class="flex flex-wrap gap-4 mb-10">
                    <span
                        class="px-3 py-1.5 bg-[#4D40AC] text-white text-[10px] sm:text-xs font-bold rounded-md"
                        >METRO SUR L12</span
                    >
                    <span
                        class="px-3 py-1.5 bg-[#4D40AC] text-white text-[10px] sm:text-xs font-bold rounded-md"
                        >RENFE C5</span
                    >
                </div>

                <a
                    href="https://www.google.com/maps/search/?api=1&query=Edificio+Departamental+I+URJC+Mostoles"
                    target="_blank"
                    class="inline-flex items-center justify-center px-6 py-3 bg-[#221965] text-white font-bold rounded-xl hover:bg-[#4D40AC] transition-colors duration-300 group shadow-md"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5 mr-3 transition-transform group-hover:scale-110"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                        ></path><circle cx="12" cy="10" r="3"></circle></svg
                    >
                    Ver en Google Maps
                </a>
            </div>

            <a
                href="https://www.google.com/maps/search/?api=1&query=Edificio+Departamental+I+URJC+Mostoles"
                target="_blank"
                class="rounded-xl overflow-hidden shadow-sm border border-gray-100 h-full min-h-[300px] block group relative"
                data-aos="fade-left"
            >
                <div
                    class="absolute inset-0 bg-[#221965]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center z-10"
                >
                    <span
                        class="bg-white/90 text-[#221965] px-4 py-2 rounded-lg font-black text-sm shadow-xl transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
                        data-i18n="location.maps.hover"
                        >Ver ubicación exacta</span
                    >
                </div>
                <img
                    src="https://images.unsplash.com/photo-1562774053-701939374585?auto=format&fit=crop&q=80&w=800"
                    alt="Campus de Móstoles de la URJC"
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                />
            </a>
        </div>
    </div>
</section>
