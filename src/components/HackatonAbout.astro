---
const features = [
    {
        titleKey: "about.free.title",
        descKey: "about.free.desc",
        title: "Entrada Gratuita",
        description:
            "Participa sin coste alguno en el evento tecnológico más importante del campus. ¡No pierdas tu plaza!",
        icon: "🎟️",
    },
    {
        titleKey: "about.teams.title",
        descKey: "about.teams.desc",
        title: "Equipos Flexibles",
        description:
            "Colabora en grupos de 1 a 5 personas para desarrollar las soluciones más innovadoras y competitivas.",
        icon: "👥",
    },
    {
        titleKey: "about.challenges.title",
        descKey: "about.challenges.desc",
        title: "3 Retos a Elegir",
        description:
            "Especialízate en ML/DL, Optimización y Metaheurísticas, o Agentes y Aprendizaje por Refuerzo.",
        icon: "🧩",
    },
];
---

<section id="que-es" class="py-20 bg-[#F4F5F0]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
            <h2
                class="text-3xl md:text-4xl font-bold text-[#4D40AC] mb-4"
                data-i18n="about.suptitle"
            >
                Detalles del Evento
            </h2>
            <div class="h-1 w-24 bg-[#221965] mx-auto rounded-full mb-6"></div>

            <p
                class="text-lg text-gray-700 max-w-3xl mx-auto leading-relaxed"
                data-i18n="about.desc"
            >
                Únete a la competición insignia de la AIA. Tres retos diseñados
                para poner a prueba tus habilidades y conectarte con el futuro
                de la tecnología.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                features.map((item, index) => (
                    <div
                        class="bg-white rounded-xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 flex flex-col items-center text-center border border-gray-100"
                        data-aos="fade-up"
                        data-aos-delay={index * 100}
                    >
                        <div class="text-4xl mb-6 p-3 bg-indigo-50 rounded-full w-20 h-20 flex items-center justify-center">
                            {item.icon}
                        </div>

                        <h3
                            class="text-xl font-bold text-[#221965] mb-4"
                            data-i18n={item.titleKey}
                        >
                            {item.title}
                        </h3>

                        <p
                            class="text-gray-600 leading-relaxed"
                            data-i18n={item.descKey}
                        >
                            {item.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
