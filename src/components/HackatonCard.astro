---
interface Props {
    title: string;
    description: string;
    icon?: string;
    delay?: number;
}

const { title, description, icon, delay = 0 } = Astro.props;
---

<div
    class="group p-8 bg-white/5 backdrop-blur-md border border-white/10 rounded-[2rem] hover:bg-white/10 hover:border-[#4D40AC]/40 transition-all duration-500 hover:shadow-2xl hover:shadow-[#4D40AC]/20 flex flex-col items-start text-left h-full"
    data-aos="fade-up"
    data-aos-delay={delay}
>
    {
        icon && (
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#4D40AC] to-[#221965] flex items-center justify-center text-3xl mb-8 group-hover:scale-110 transition-transform duration-500 shadow-lg shadow-[#4D40AC]/30">
                {icon}
            </div>
        )
    }
    <h4
        class="text-xl font-black text-white mb-4 group-hover:text-[#4D40AC] transition-colors duration-300 uppercase tracking-tight leading-tight"
    >
        {title}
    </h4>
    <p class="text-white/60 text-base leading-relaxed font-medium">
        {description}
    </p>
</div>
