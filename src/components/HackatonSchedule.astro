---
const scheduleData = [
  {
    day: "14 abr 2026 - Día de la IA",
    items: [
      { time: "11:00 - 11:10", title: "Inauguración", person: "J.M. Colmenar Verdugo / I. Ramírez Díaz" },
      { time: "11:10 - 11:30", title: "Metaheurísticas, agentes y otros cuentos: la IA en la investigación y la ciberseguridad", person: "Sergio Pérez Peló" },
      { time: "11:30 - 12:15", title: "Evaluación de proyectos de Procesamiento de Lenguaje Natural", person: "Marta Guerrero Nieto" },
      { time: "12:15 - 12:45", title: "Pausa Café", person: "" },
      { time: "12:45 - 13:30", title: "Ponencia (título por confirmar)", person: "Christian Blum" },
      { time: "13:30 - 13:50", title: "Aplicaciones de PLN en el dominio biomédico", person: "Soto Montalvo" },
      { time: "13:50 - 14:10", title: "De la generación de texto a la mejora de modelos mediante LLMs", person: "Natalia Madrueño" },
      { time: "14:10 - 14:20", title: "Presentación empresa + Cierre", person: "" },
    ]
  },
  {
    day: "14 abr 2026 - Hackathon — Día 1",
    items: [
      { time: "16:00 - 16:45", title: "Check-in y entrega de merchandising", person: "Organización AIA" },
      { time: "17:00 - 17:15", title: "Presentaciones oficiales (AIA, Grupos de Investigación, Patrocinadores)", person: "Organización AIA" },
      { time: "17:15 - 18:00", title: "Presentación de agenda, ubicaciones y plantilla de solución", person: "Organización AIA" },
      { time: "18:00 - 18:45", title: "Presentación de retos del Hackathon (15 min por reto)", person: "Organización AIA" },
      { time: "18:45 - 19:15", title: "Coffee-Activation", person: "" },
      { time: "19:15 - 20:45", title: "Code Cooking — sesión de desarrollo", person: "Participantes" },
    ]
  },
  {
    day: "15 abr 2026 - Hackathon — Día 2",
    items: [
      { time: "11:00 - 11:30", title: "Coffee-Activation", person: "" },
      { time: "11:30 - 17:30", title: "Code Cooking — sesión de desarrollo", person: "Participantes" },
      { time: "17:30 - 18:00", title: "Coffee-Activation", person: "" },
      { time: "18:00 - 20:00", title: "Code Cooking — sesión de desarrollo", person: "Participantes" },
    ]
  },
  {
    day: "16 abr 2026 - Hackathon — Día 3",
    items: [
      { time: "11:00 - 11:30", title: "Coffee-Activation", person: "" },
      { time: "11:30 - 13:00", title: "Code Cooking — sesión de desarrollo", person: "Participantes" },
      { time: "13:00 - 14:00", title: "Preparación de presentaciones", person: "Participantes" },
      { time: "14:00 - 15:00", title: "Límite de entrega de proyectos + Descanso comida", person: "" },
      { time: "15:00 - 16:30", title: "Presentaciones de los equipos (3 min por equipo)", person: "Participantes" },
      { time: "16:30 - 17:00", title: "Deliberación de jueces", person: "Jurado" },
      { time: "17:00 - 18:30", title: "Resultados, entrega de premios y cierre del evento", person: "Organización AIA" },
    ]
  }
];
---

<section id="horario" class="py-24 bg-white relative overflow-hidden transition-colors duration-300">
  <!-- Decorative Elements -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-[#4D40AC]/10 rounded-full -mr-32 -mt-32 blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#221965]/10 rounded-full -ml-48 -mb-48 blur-3xl"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-3xl md:text-5xl font-black text-[#221965] mb-4">
        Horario del Evento
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto text-lg">
        Planificación detallada de las jornadas del Hackathon y el Día de la IA.
      </p>
    </div>

    <div class="space-y-12">
      {scheduleData.map((section, sIndex) => (
        <div class="bg-white dark:bg-[#1a1443] rounded-2xl shadow-xl overflow-hidden border border-gray-100 dark:border-white/10" data-aos="fade-up" data-aos-delay={sIndex * 100}>
          <!-- Day Header -->
          <div class="bg-gradient-to-r from-[#221965] to-[#4D40AC] px-8 py-5">
            <h3 class="text-xl font-bold text-white flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 opacity-75" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {section.day}
            </h3>
          </div>

          <!-- Schedule Table-like List -->
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-gray-50/80 dark:bg-black/20">
                  <th class="px-8 py-5 text-xs font-black text-[#4D40AC] dark:text-indigo-200 uppercase tracking-wider w-32 md:w-48 whitespace-nowrap text-center">Horario</th>
                  <th class="px-8 py-4 text-xs font-black text-[#4D40AC] dark:text-indigo-200 uppercase tracking-wider">Actividad</th>
                  <th class="px-8 py-4 text-xs font-black text-[#4D40AC] dark:text-indigo-200 uppercase tracking-wider hidden md:table-cell text-right pr-12">Ponente / Responsable</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                {section.items.map((item, iIndex) => (
                  <tr class="hover:bg-indigo-50/30 dark:hover:bg-indigo-400/5 transition-all duration-300 group">
                    <td class="px-8 py-6 align-top text-center">
                      <span class="text-xs md:text-sm font-bold text-[#221965] dark:!text-white bg-indigo-50 dark:!bg-[#221965] border border-indigo-100 dark:border-indigo-400/30 px-4 py-2 rounded-xl shadow-sm group-hover:bg-[#4D40AC] group-hover:!text-white transition-all duration-300 whitespace-nowrap inline-block">
                        {item.time}
                      </span>
                    </td>
                    <td class="px-8 py-6 align-top">
                      <div class="flex flex-col gap-2">
                        <span class="text-base md:text-lg font-bold text-[#221965] dark:text-gray-100 leading-tight group-hover:text-[#4D40AC] dark:group-hover:text-indigo-300 transition-colors">
                          {item.title}
                        </span>
                        {item.person && (
                          <span class="text-sm text-gray-500 dark:text-gray-400 md:hidden flex items-center gap-1.5 italic">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            {item.person}
                          </span>
                        )}
                      </div>
                    </td>
                    <td class="px-8 py-6 align-top hidden md:table-cell text-right pr-12">
                      {item.person ? (
                        <div class="inline-flex items-center gap-3 text-sm text-gray-600 dark:text-gray-300 font-medium bg-gray-50 dark:bg-white/5 px-3 py-1.5 rounded-lg border border-gray-100 dark:border-white/5">
                           <div class="w-1.5 h-1.5 rounded-full bg-[#4D40AC] dark:bg-indigo-400"></div>
                           {item.person}
                        </div>
                      ) : (
                        <span class="text-gray-400 dark:text-gray-500 text-sm italic">-</span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
