---
const schedule = [
  {
    day: "VIERNES",
    date: "15 de Noviembre",
    time: "17:00",
    title: "Apertura y Retos",
    subtitle: "Recepción de participantes y formación de equipos",
    description: "Comenzamos con la acreditación de los hackers, una cena de bienvenida y el anuncio oficial de los desafíos tecnológicos patrocinados por las empresas líderes del sector."
  },
  {
    day: "SÁBADO",
    date: "16 de Noviembre",
    time: "09:00",
    title: "Hacking & Mentoreo",
    subtitle: "Día completo de desarrollo intensivo",
    description: "Más de 24 horas ininterrumpidas de programación creativa. Contaremos con mentores especializados de la industria que pasarán por las mesas para ofrecer feedback técnico y estratégico."
  },
  {
    day: "DOMINGO",
    date: "17 de Noviembre",
    time: "10:00",
    title: "Final y Premios",
    subtitle: "Presentaciones, jurado y gala",
    description: "Los equipos realizarán un pitch de 3 minutos frente a un jurado de expertos. Finalizaremos con la ceremonia de entrega de premios a los proyectos más innovadores y escalables."
  }
];
---

<section id="cronograma" class="py-32 bg-white overflow-hidden">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
        
        <div class="mb-24 text-center" data-aos="fade-up">
            <h2 class="text-4xl md:text-6xl font-black text-[#221965] mb-6">
                Cronograma
            </h2>
            <div class="h-2 w-32 bg-[#4D40AC] mx-auto rounded-full"></div>
        </div>

        <div class="relative">
            <!-- Continuous Timeline Line -->
            <div class="absolute left-1.5 top-0 bottom-0 w-0.5 bg-gray-100"></div>

            <div class="space-y-24">
                {schedule.map((item, index) => (
                    <div class="relative pl-10 md:pl-20 group" data-aos="fade-up" data-aos-delay={index * 100}>
                        
                        <!-- Timeline Node -->
                        <div class="absolute left-0 top-2 w-4 h-4 rounded-full bg-white border-4 border-[#4D40AC] z-10 shadow-sm transition-transform duration-300 group-hover:scale-125"></div>

                        <div class="flex flex-col gap-8">
                            <!-- Time & Day Hero Block -->
                            <div class="flex flex-wrap items-end gap-6 border-b border-gray-50 pb-8">
                                <span class="text-4xl md:text-7xl font-black text-[#221965] leading-none tracking-tighter">
                                    {item.time}
                                </span>
                                <div class="flex flex-col mb-1">
                                    <span class="text-sm font-black text-[#4D40AC] tracking-[0.3em] uppercase">
                                        {item.day}
                                    </span>
                                    <span class="text-xs font-bold text-gray-300 uppercase tracking-widest">
                                        {item.date}
                                    </span>
                                </div>
                            </div>

                            <!-- Content -->
                            <div class="max-w-3xl">
                                <h3 class="text-2xl md:text-4xl font-extrabold text-[#221965] mb-4 group-hover:text-[#4D40AC] transition-colors duration-300">
                                    {item.title}
                                </h3>

                                <p class="text-[#4D40AC] font-bold text-base md:text-xl mb-6">
                                    {item.subtitle}
                                </p>

                                <p class="text-gray-500 leading-relaxed text-lg md:text-xl font-medium">
                                    {item.description}
                                </p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

    </div>
</section>
