---
interface Props {
    title: string;
    description: string;
    icon: string;
    id: string;
    titleKey: string;
    descKey: string;
    idKey: string;
}

const { title, description, icon, id, titleKey, descKey, idKey } = Astro.props;
---

<div
    class="bg-white rounded-xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col items-center text-center border border-gray-100 group relative overflow-hidden h-full"
    data-aos="fade-up"
>
    <!-- Icon Wrapper -->
    <div
        class="text-[#4D40AC] mt-6 mb-6 p-4 bg-indigo-50 rounded-full group-hover:scale-110 transition-transform duration-300"
    >
        <span class="text-4xl">{icon}</span>
    </div>

    <div class="mb-2">
        <span
            class="text-[10px] font-black text-[#4D40AC] border border-[#4D40AC]/20 px-2 py-0.5 rounded uppercase tracking-widest"
            data-i18n={idKey}
        >
            {id}
        </span>
    </div>

    <h3 class="text-xl font-bold text-[#221965] mb-4" data-i18n={titleKey}>
        {title}
    </h3>

    <p class="text-gray-600 leading-relaxed text-sm" data-i18n={descKey}>
        {description}
    </p>
</div>
