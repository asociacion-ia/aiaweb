---
import HackatonChallengeCard from "./HackatonChallengeCard.astro";

const challenges = [
    {
        titleKey: "challenges.ml.title",
        descKey: "challenges.ml.desc",
        idKey: "challenges.ml.id",
        title: "Reto 1",
        description:
            "Reto de optimización y metaheurísticas.",
        icon: "🌱",
        id: "RETO 01",
        link: "https://grafo-hackathon-ia.streamlit.app/Reto_Principiante",
    },
    {
        titleKey: "challenges.opt.title",
        descKey: "challenges.opt.desc",
        idKey: "challenges.opt.id",
        title: "Reto 2 ML",
        description:
            "Aplica técnicas de Machine Learning y Deep Learning para resolver problemas complejos de clasificación y predicción.",
        icon: "🧠",
        id: "RETO 02",
        link: "https://github.com/maybepueblo/Breaking-Data-Reto-2",
    },
    {
        titleKey: "challenges.rl.title",
        descKey: "challenges.rl.desc",
        idKey: "challenges.rl.id",
        title: "Reto 3",
        description:
            "Desafío avanzado para poner a prueba tus habilidades de programación y lógica.",
        icon: "🤖",
        id: "RETO 03",
        link: "https://github.com/KaiserAI/Breaking-Data-Reto-3",
    },
];
---

<div class="flex flex-col gap-12">
    <!-- 3 Challenges Grid -->
    <div class="grid md:grid-cols-3 gap-8">
        {
            challenges.map((challenge, index) => (
                <HackatonChallengeCard
                    title={challenge.title}
                    description={challenge.description}
                    icon={challenge.icon}
                    id={challenge.id}
                    titleKey={challenge.titleKey}
                    descKey={challenge.descKey}
                    idKey={challenge.idKey}
                    link={challenge.link}
                    data-aos-delay={index * 100}
                />
            ))
        }
    </div>

    <!-- Registration Button -->
    <div class="flex justify-center" data-aos="fade-up" data-aos-delay="400">
        <a
            href="https://forms.office.com/pages/responsepage.aspx?id=6sSEXw03nkuDDHVvi_G1H3HGP-9Br_NNpGoLsLite4xUQk1TQ0RWWDQ0U1pNUTRJTThHMFUzTFlQQS4u&origin=lprLink&route=shorturl"
            target="_blank"
            class="group relative inline-flex items-center justify-center px-12 py-5 font-black text-white bg-[#4D40AC] rounded-2xl overflow-hidden shadow-2xl hover:bg-[#3d328a] transition-all duration-300 transform hover:-translate-y-1"
            data-i18n="challenges.btn.register"
        >
            <span class="relative z-10 flex items-center gap-3">
                Inscribirse al Hackathon
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6 transition-transform group-hover:translate-x-2"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                        points="12 5 19 12 12 19"></polyline></svg
                >
            </span>
            <div
                class="absolute inset-0 bg-gradient-to-r from-[#4D40AC] to-[#221965] opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            >
            </div>
        </a>
    </div>
</div>
