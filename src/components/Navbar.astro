---
import logoaso from "../assets/logoaso.png";
---

<nav class="bg-[#F4F5F0] shadow-lg fixed w-full z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
            <div class="flex items-center">
                <a href="/aiaweb/#inicio" class="flex items-center gap-3">
                    <img
                        class="h-10 w-10 rounded-lg object-contain shadow-sm"
                        src={logoaso.src}
                        alt="AIA Logo"
                    />
                    <span
                        class="font-black text-[#221965] tracking-tight hidden sm:block"
                        >AIA URJC</span
                    >
                </a>
            </div>

            <div class="hidden md:ml-6 md:flex md:items-center md:space-x-8">
                <a
                    href="/aiaweb/"
                    class="text-[#4D40AC] hover:text-[#221965] px-3 py-2 text-sm font-medium transition-colors"
                    data-i18n="nav.inicio">Inicio</a
                >
                <a
                    href="/aiaweb/#sobre-nosotros"
                    class="text-[#221965] hover:text-[#4D40AC] px-3 py-2 text-sm font-medium transition-colors"
                    data-i18n="nav.sobre">Sobre Nosotros</a
                >
                <a
                    href="/aiaweb/hackaton"
                    class="text-[#221965] hover:text-[#4D40AC] px-3 py-2 text-sm font-medium transition-colors"
                    data-i18n="nav.hackaton">Hackathon</a
                >
                <a
                    href="/aiaweb/#contacto"
                    class="text-[#221965] hover:text-[#4D40AC] px-3 py-2 text-sm font-medium transition-colors"
                    data-i18n="nav.contacto">Contacto</a
                >
            </div>

            <!-- Dark mode toggle + mobile hamburger -->
            <div class="flex items-center gap-2">
                <!-- Dark Mode Toggle -->
                <button
                    id="theme-toggle"
                    type="button"
                    aria-label="Cambiar modo"
                    class="p-2 rounded-lg text-[#221965] hover:bg-[#4D40AC]/10 transition-colors duration-200 focus:outline-none"
                >
                    <!-- Sun icon (shown in dark mode) -->
                    <svg
                        id="icon-sun"
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5 hidden"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="12" cy="12" r="5"></circle><line
                            x1="12"
                            y1="1"
                            x2="12"
                            y2="3"></line><line x1="12" y1="21" x2="12" y2="23"
                        ></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"
                        ></line><line
                            x1="18.36"
                            y1="18.36"
                            x2="19.78"
                            y2="19.78"></line><line
                            x1="1"
                            y1="12"
                            x2="3"
                            y2="12"></line><line x1="21" y1="12" x2="23" y2="12"
                        ></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
                        ></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"
                        ></line>
                    </svg>
                    <!-- Moon icon (shown in light mode) -->
                    <svg
                        id="icon-moon"
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
                        ></path>
                    </svg>
                </button>

                <!-- Language Toggle -->
                <button
                    id="lang-toggle"
                    type="button"
                    aria-label="Cambiar idioma"
                    class="px-2 py-1 rounded-lg text-[10px] font-black text-[#221965] border border-[#221965]/20 hover:bg-[#4D40AC]/10 transition-colors duration-200 focus:outline-none tracking-widest"
                >
                    EN
                </button>

                <div class="-mr-2 flex items-center md:hidden">
                    <button
                        id="menu-btn"
                        type="button"
                        class="inline-flex items-center justify-center p-2 rounded-md text-[#221965] hover:bg-[#4D40AC] hover:text-[#F4F5F0] focus:outline-none transition-colors"
                        aria-controls="mobile-menu"
                        aria-expanded="false"
                    >
                        <span class="sr-only">Abrir menú</span>
                        <svg
                            id="icon-menu"
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-6 w-6 block"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                        <svg
                            id="icon-close"
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-6 w-6 hidden"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
